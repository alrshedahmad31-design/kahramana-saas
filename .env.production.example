# ============================================================
# Kahramana Baghdad — Production Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and name it .env.local for local dev
#   2. For production: set each variable in Vercel dashboard
#      via: vercel env add VARIABLE_NAME
#   3. NEVER commit .env.local to git
#
# This file is safe to commit — values are placeholders only.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────

# Project URL — safe for client-side (NEXT_PUBLIC_ prefix)
# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon key — safe for client-side, enforces RLS
# Found in: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — SERVER ONLY, bypasses RLS
# Set in Vercel as Production-only (never Preview or Development)
# Found in: Supabase Dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site ──────────────────────────────────────────────────────────────────────

# Production domain — used for auth redirects and canonical URLs
# Must match Supabase Auth → Settings → Site URL
NEXT_PUBLIC_SITE_URL=https://kahramanat.com
