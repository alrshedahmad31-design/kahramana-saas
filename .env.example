# KAHRAMANA BAGHDAD — Environment Variables
# Copy to .env.local — never commit .env.local

# ─── SUPABASE ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — never expose to client

# ─── SESSION BINDING (L1) ─────────────────────────
# HMAC secret used to bind the recovery cookie to the user_id it was minted for.
# Without this, /set-password cannot tell whether kah_recovery_flow was issued
# for the same user the active session belongs to (cross-account swap risk).
# Generate with: openssl rand -hex 32  (must be 32+ characters)
SESSION_BIND_SECRET=                # SERVER ONLY — required at runtime

# ─── SANITY ───────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                   # SERVER ONLY for mutations

# ─── BRANCH WHATSAPP NUMBERS ──────────────────────
NEXT_PUBLIC_WA_RIFFA=               # e.g. 97317xxxxxx (no + sign)
NEXT_PUBLIC_WA_QALLALI=             # e.g. 97317xxxxxx
# NEXT_PUBLIC_WA_BADI=              # Planned — add when Al-Badi' opens

# ─── ANALYTICS ────────────────────────────────────
NEXT_PUBLIC_GA_ID=                  # G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=             # Microsoft Clarity project ID

# ─── SENTRY ───────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # SERVER ONLY

# ─── UPSTASH REDIS (Phase 2+) ─────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── PHASE 6 — PAYMENTS ───────────────────────────
TAP_SECRET_KEY=                     # SERVER ONLY — Tap Payments secret
PAYMENT_WEBHOOK_SECRET=             # SERVER ONLY — HMAC secret for Tap webhook
# TAP_WEBHOOK_ALLOWED_IPS — comma-separated list of Tap webhook source IPs.
# KAH-2026-05-07: hardens /api/webhooks/tap as a defence-in-depth layer in
# front of HMAC verification. Leave UNSET during soft-launch (the route then
# skips the check) until the canonical IP list is pulled from Tap support
# or observed in payment_webhooks. Example: TAP_WEBHOOK_ALLOWED_IPS=1.2.3.4,5.6.7.8
TAP_WEBHOOK_ALLOWED_IPS=
NEXT_PUBLIC_SITE_URL=               # e.g. https://kahramanat.com — used in Tap redirect URL
# BENEFIT_PAY_MERCHANT_ID=
# BENEFIT_PAY_API_KEY=
# CREDIMAX_API_KEY=

# ─── PHASE 6 — WHATSAPP API (add when approved) ───
# WATI_API_ENDPOINT=
# WATI_ACCESS_TOKEN=

# ─── EMAIL (Resend) ───────────────────────────────
RESEND_API_KEY=                     # SERVER ONLY — from resend.com dashboard
EMAIL_FROM=كهرمانة <noreply@kahramanat.com>
# CONTACT_NOTIFY_EMAIL — owner inbox that receives contact form notifications.
# Once set, every valid contact submission triggers an email to this address.
# Leave UNSET to disable the notification (messages still save to Supabase).
CONTACT_NOTIFY_EMAIL=               # e.g. info@kahramanat.com

# ─── CLOUDFLARE TURNSTILE ─────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=     # public key from Cloudflare dashboard
TURNSTILE_SECRET_KEY=               # SERVER ONLY — secret key

# ─── VERCEL ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://kahramanat.com
