# ─────────────────────────────────────────────────────────────────────────────
# .env.test — Playwright E2E environment
# Copy this file to .env.test and fill in the placeholders below.
# .env.test is gitignored; never commit it.
# ─────────────────────────────────────────────────────────────────────────────
#
# What this file does:
#   - Drives the 60 Playwright specs in tests/e2e/**
#   - tests/global-setup.ts uses SERVICE_ROLE_KEY to auto-create 6 test users
#     in Supabase Auth + staff_basic before the suite starts
#   - tests/global-teardown.ts removes them when the suite finishes
#
# Run with:
#   npm run test:e2e            # full suite (auth + realtime)
#   npm run test:e2e:auth       # auth-only (browser, headed)
#   npm run test:e2e:realtime   # realtime/RLS only (no browser)
#
# Prerequisites (one-time, run via Browsing Agent or manually):
#   1. branches.riffa and branches.qallali rows exist (seeded by 010_production_seed)
#   2. Realtime publication includes orders + order_items:
#        ALTER PUBLICATION supabase_realtime ADD TABLE orders;
#        ALTER PUBLICATION supabase_realtime ADD TABLE order_items;
#   3. RLS policies from 028_security_lockdown applied (orders_select_staff etc.)
#

# ─── Supabase project ─────────────────────────────────────────────────────────
# Use a STAGING project, not production. If only one project exists, that's
# fine — the E2E users live under the e2e-*@test.kahramana sub-domain so they
# can't collide with real staff. Teardown removes them after the run.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVER ONLY — used by global-setup.ts to create test users.
# Get from Supabase Dashboard → Project Settings → API → service_role key.
# NEVER paste this in any file under src/.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Test runner ──────────────────────────────────────────────────────────────
# E2E_BASE_URL: which deployment to hit.
#   - Local dev:  http://localhost:3000  (playwright starts `npm run dev` automatically)
#   - Vercel:     https://kahramana.vercel.app
# E2E_TEST_PASSWORD: shared password for all 6 generated test users.
#   Must satisfy Supabase password policy (≥ 8 chars, mixed case + digit recommended).

E2E_BASE_URL=http://localhost:3000
E2E_TEST_PASSWORD=E2eTest!2026

# ─── Test user matrix (auto-created — DO NOT EDIT) ────────────────────────────
# These are the emails the suite expects. They are NOT env vars — listed here
# only for reference so you know what global-setup.ts will create.
#
#   e2e-owner@test.kahramana          owner            (no branch — global)
#   e2e-manager@test.kahramana        general_manager  (no branch — global)
#   e2e-branch-mgr@test.kahramana     branch_manager   riffa
#   e2e-cashier-riffa@test.kahramana  cashier          riffa
#   e2e-cashier-qallali@test.kahramana cashier         qallali
#   e2e-driver@test.kahramana         driver           riffa
#
# Each gets E2E_TEST_PASSWORD as its password.

# ─── Optional: CI ──────────────────────────────────────────────────────────────
# CI=true                        # enables Playwright retries (set automatically by GitHub Actions)
# E2E_ENABLED=true               # GitHub repo variable to gate E2E job in .github/workflows/e2e.yml
