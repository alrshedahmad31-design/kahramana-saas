# .env.test — E2E test environment
# Copy this file to .env.test and fill in real values.
# NEVER commit .env.test — it is in .gitignore.

# Supabase project (same project as production, or a staging project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Test users — must be real auth.users entries in the project
# Cashier: active staff, role=cashier, branch_id=riffa
E2E_CASHIER_EMAIL=test-cashier-riffa@example.com
E2E_CASHIER_PASSWORD=your_secure_password
E2E_CASHIER_BRANCH=riffa

# Owner: active staff, role=owner
E2E_OWNER_EMAIL=test-owner@example.com
E2E_OWNER_PASSWORD=your_secure_password

# ── Manual check required before running ──────────────────────────────────────
# Verify in Supabase Dashboard → Database → Replication:
#   - Publication: supabase_realtime
#   - Table: orders → must be listed (checkbox enabled)
# If not enabled, run:
#   ALTER PUBLICATION supabase_realtime ADD TABLE orders;
