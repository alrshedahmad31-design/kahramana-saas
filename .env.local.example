# Kahramana — Environment Variables
# Copy to .env.local and fill in values from your Supabase project dashboard.

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service-role key — required for server actions (checkout, coupons, KDS, etc.)
# Get from: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Payment Gateways (Development) ───────────────────────────────────────────
# Benefit Pay — apply via Benefit BSC (pending merchant approval)
BENEFIT_MERCHANT_ID=your_merchant_id

# Tap Payments — sandbox keys from dashboard.tap.company
TAP_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_TAP_PUBLIC_KEY=pk_test_xxxxx

# Webhook signature secret — set same value in Tap dashboard > Webhooks
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# ── Test users (development only — requires 006_seed_test_staff.sql) ─────────
#
#  owner@kahramana.test    / owner123    → full access (all branches, all features)
#  manager@kahramana.test  / manager123  → branch_manager (Riffa branch)
#  kitchen@kahramana.test  / kitchen123  → kitchen role (KDS only)
#
# Login at: http://localhost:3000/login  (AR)
#           http://localhost:3000/en/login  (EN)
